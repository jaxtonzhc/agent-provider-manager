{
  "version": 1,
  "agents": {
    "claude-code": {
      "name": "Claude Code",
      "config_paths": ["~/.claude/settings.json"],
      "protocol": "anthropic",
      "website": "https://docs.anthropic.com/en/docs/claude-code",
      "description": "Anthropic's official CLI coding agent"
    },
    "codex": {
      "name": "Codex",
      "config_paths": ["~/.codex/config.toml", "~/.codex/auth.json"],
      "protocol": "responses",
      "website": "https://github.com/openai/codex",
      "description": "OpenAI's CLI coding agent (uses Responses API)"
    },
    "cursor": {
      "name": "Cursor",
      "config_paths": ["~/.cursor/mcp.json"],
      "protocol": "openai-compatible",
      "website": "https://cursor.sh",
      "description": "AI-first code editor"
    },
    "copilot": {
      "name": "GitHub Copilot",
      "config_paths": ["~/.config/github-copilot/"],
      "protocol": "openai",
      "website": "https://copilot.github.com",
      "description": "GitHub's AI pair programmer"
    },
    "windsurf": {
      "name": "Windsurf",
      "config_paths": ["~/.windsurf/"],
      "protocol": "openai-compatible",
      "website": "https://codeium.com/windsurf",
